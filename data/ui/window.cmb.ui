<?xml version="1.0" encoding="UTF-8"?>
<!-- Cambalache-compatible UI for Knot GTK4 -->
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.0"/>
  
  <object class="AdwApplicationWindow" id="KnotWindow">
    <property name="width-request">400</property>
    <property name="height-request">300</property>
    <property name="default-width">1200</property>
    <property name="default-height">800</property>
    <property name="title">Knot</property>
    
    <child>
      <object class="AdwToolbarView" id="toolbar_view">
        
        <child type="top">
          <object class="AdwHeaderBar" id="header_bar">
            <child type="start">
              <object class="GtkToggleButton" id="sidebar_toggle">
                <property name="icon-name">sidebar-show-symbolic</property>
                <property name="tooltip-text">Toggle Sidebar (F9)</property>
                <property name="active">1</property>
              </object>
            </child>
            <child type="start">
              <object class="GtkButton" id="new_note_btn">
                <property name="icon-name">document-new-symbolic</property>
                <property name="tooltip-text">New Note (Ctrl+N)</property>
              </object>
            </child>
            <child type="end">
              <object class="GtkMenuButton" id="menu_button">
                <property name="icon-name">open-menu-symbolic</property>
              </object>
            </child>
          </object>
        </child>
        
        <property name="content">
          <object class="AdwOverlaySplitView" id="split_view">
            <property name="sidebar-position">start</property>
            <property name="show-sidebar">1</property>
            <property name="min-sidebar-width">280.0</property>
            <property name="max-sidebar-width">380.0</property>
            
            <!-- Sidebar -->
            <property name="sidebar">
              <object class="AdwToolbarView" id="sidebar_view">
                <property name="width-request">250</property>
                <style>
                  <class name="sidebar"/>
                </style>
                
                <child type="top">
                  <object class="AdwHeaderBar" id="sidebar_header">
                    <property name="show-end-title-buttons">0</property>
                    <property name="show-start-title-buttons">0</property>
                    <property name="centering-policy">strict</property>
                    
                    <property name="title-widget">
                      <object class="AdwWindowTitle" id="sidebar_title">
                        <property name="title">Notes</property>
                      </object>
                    </property>
                    
                    <child type="end">
                      <object class="GtkButton" id="sidebar_new_btn">
                        <property name="icon-name">list-add-symbolic</property>
                        <property name="tooltip-text">New Note</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
                
                <property name="content">
                  <object class="GtkBox" id="sidebar_content">
                    <property name="orientation">vertical</property>
                    
                    <child>
                      <object class="GtkSearchEntry" id="search_entry">
                        <property name="placeholder-text">Search notes...</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <property name="margin-top">6</property>
                        <property name="margin-bottom">6</property>
                      </object>
                    </child>
                    
                    <child>
                      <object class="GtkScrolledWindow" id="sidebar_scroll">
                        <property name="hscrollbar-policy">never</property>
                        <property name="vexpand">1</property>
                        
                        <child>
                          <object class="GtkListBox" id="notes_list">
                            <property name="selection-mode">single</property>
                            <style>
                              <class name="navigation-sidebar"/>
                            </style>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
              </object>
            </property>
            
            <!-- Main Content -->
            <property name="content">
              <object class="GtkBox" id="editor_box">
                <property name="orientation">vertical</property>
                <style>
                  <class name="card"/>
                </style>
                
                <child>
                  <object class="GtkEntry" id="title_entry">
                    <property name="placeholder-text">Note title...</property>
                    <property name="margin-top">16</property>
                    <property name="margin-bottom">8</property>
                    <property name="margin-start">16</property>
                    <property name="margin-end">16</property>
                    <style>
                      <class name="title-2"/>
                    </style>
                  </object>
                </child>
                
                <child>
                  <object class="GtkScrolledWindow" id="editor_scroll">
                    <property name="vexpand">1</property>
                    <property name="margin-start">12</property>
                    <property name="margin-end">12</property>
                    <property name="margin-bottom">12</property>
                    
                    <child>
                      <object class="GtkTextView" id="text_view">
                        <property name="wrap-mode">word-char</property>
                        <property name="top-margin">12</property>
                        <property name="bottom-margin">12</property>
                        <property name="left-margin">12</property>
                        <property name="right-margin">12</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
          </object>
        </property>
      </object>
    </child>
  </object>
</interface>
